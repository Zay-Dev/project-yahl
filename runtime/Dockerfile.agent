FROM node:22

WORKDIR /app

RUN corepack enable

COPY package.json ./
COPY pnpm-workspace.yaml ./
COPY runtime/package.json ./runtime/package.json
COPY pnpm-lock.yaml* ./

RUN if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile; else pnpm install; fi

COPY runtime/agent ./runtime/agent
COPY runtime/orchestrator ./runtime/orchestrator
COPY runtime/shared ./runtime/shared
COPY runtime/tsconfig.json ./runtime/tsconfig.json

CMD ["pnpm", "--silent", "--filter", "runtime", "run", "agent", "--", "--daemon"]
