```ai.logic

CONTEXT: {
  const base = { a: 1, b: 2 };

  (() => ({
    ...base,
    c: base.a + base.b,
  }))
}

for each i of [1..5] CONTEXT: {
  (() => ({
    c: context.stage.c + context.stage.i,
  }));
}

for each i of [1..5,+2] {
  c += i;
}

IF: context.context.c % 2 === 0;
   c = context.context.c * 2;
 ELSE IF: context.context.c > 30;
   c = context.context.c - 2;
 ELSE:
   c = context.context.c / 2;
 END:

c += /ask-user(which number of 1,2,3,4,5);

const result = {a,b,c};

CONTEXT: {
  (() => ({ result: context.context.result }));
}
```