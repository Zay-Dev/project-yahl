  "version": "1.0.0",
  "description": "",
  "scripts": {
    "compose:down": "docker compose down",
    "compose:up": "docker compose up -d --build",
    "compose:runtime:down": "docker compose -f runtime/docker-compose.yml down",
    "compose:runtime:up": "docker compose -f runtime/docker-compose.yml up -d --build",
    "dev": "pnpm -r --parallel --filter runtime --filter server --filter web run dev",
    "dev:runtime": "pnpm --filter runtime run dev",
    "dev:server": "pnpm --filter server run dev",
    "dev:web": "pnpm --filter web run dev",
    "orchestrate": "pnpm --filter runtime run orchestrate",
    "test": "pnpm --filter runtime run test",
    "typecheck": "pnpm -r run typecheck"
  },
